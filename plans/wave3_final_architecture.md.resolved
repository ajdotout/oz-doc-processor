### New [src/pipeline/classify_and_bucket.py](file:///Users/aryanjain/Documents/OZL/oz-doc-processor/src/pipeline/classify_and_bucket.py) Changes

Stage 2 classifies docs and physically buckets files for auditability.

```python
def build_excel_preview(excel_md: str, lines_per_sheet: int = 10) -> str:
    # Split by "### EXTERNAL DATA SOURCE: Excel Sheet - <name>"
    # Take only the first `lines_per_sheet` lines from each sheet section
    # Concatenate section headers + lines.

async def classify_and_bucket(listing_dir: Path, force: bool = True):
    # If rerun, clear all bucket folders before rebuild
    if force:
        shutil.rmtree(listing_dir / "buckets", ignore_errors=True)
    
    # 1) Build per-file previews:
    #    - PDFs/MD: use file preview (e.g., first CLASSIFIER_LINES lines)
    #    - Excels: only first CLASSIFIER_EXCEL_SHEET_LINES from each sheet in converted markdown
    # 2) Classify each file -> one of 4 categories
    # 3) Write doc_manifest.json (with filename, category, reasoning, source path, temp md path)
    # 4) Copy source file + temp markdown into matching buckets:
    #    buckets/<category>/source/<filename>
    #    buckets/<category>/temp/<filename>.md
    # 5) Return manifest path
```

### [run_modular_pipeline.py](file:///Users/aryanjain/Documents/OZL/oz-doc-processor/run_modular_pipeline.py) Changes

Stage 3 runs extraction from manifest only. No fallback path.

```python
AGENT_ROUTING = {
    "overview":  {"om", "supplemental"},
    "financial": {"om", "proforma", "supplemental"},
    "property":  {"om", "research", "supplemental"},
    "market":    {"om", "research", "supplemental"},
    "sponsor":   {"om", "supplemental"},
}

async def run_pipeline(markdown_path: str, agent_filter: str = None):
    listing_dir = Path(markdown_path).parent
    manifest_path = listing_dir / "doc_manifest.json"
    
    if not manifest_path.exists():
        raise RuntimeError(
            "doc_manifest.json not found. Run --stage classify before extract."
        )
    
    manifest = json.loads(manifest_path.read_text())
    
    classifications = {f["filename"]: f["category"] for f in manifest["files"]}
    per_file_markdowns = {}
    for f in manifest["files"]:
        fname = f["filename"]
        stem = Path(fname).stem
        bucket_md = listing_dir / "buckets" / f["category"] / "temp" / f"{stem}.md"
        if not bucket_md.exists():
            raise RuntimeError(f"Missing bucketed markdown for {fname}. Re-run --stage classify.")
        per_file_markdowns[fname] = bucket_md.read_text()
    
    # Build per-agent content
    def build_content(agent_name):
        allowed = AGENT_ROUTING[agent_name]
        sections = []
        for fname, content in per_file_markdowns.items():
            if classifications.get(fname) in allowed:
                header = f"\n{'='*40}\nSOURCE FILE: {fname}\n{'='*40}\n\n"
                sections.append(header + content)
        return "\n".join(sections)
    
    agent_contents = {name: build_content(name) for name in AGENT_ROUTING}
    
    # Determine which agents to run
    all_agents = {
        "overview": OverviewAgent,
        "financial": FinancialAgent,
        "property": PropertyAgent,
        "market": MarketAgent,
        "sponsor": SponsorAgent,
    }
    
    if agent_filter:
        if agent_filter not in all_agents:
            logging.error(f"Unknown agent: {agent_filter}. Choose from: {list(all_agents.keys())}")
            return None
        agents_to_run = {agent_filter: all_agents[agent_filter]}
    else:
        agents_to_run = all_agents
    
    # Run agents
    tasks = [
        run_agent_in_thread(cls(), agent_contents[name])
        for name, cls in agents_to_run.items()
    ]
    results = await asyncio.gather(*tasks, return_exceptions=True)
    
    # If single-agent mode, merge into existing output
    if agent_filter:
        existing_output_path = # ... find existing JSON ...
        if existing_output_path.exists():
            existing = json.loads(existing_output_path.read_text())
            # Merge just this agent's result into existing
            # ... merge logic ...
    
    # ... rest of assembly ...
```

### CLI

```bash
# Full 3-stage pipeline (convert -> classify -> extract)
uv run python orchestrate_pipeline.py "TierraMark-at-Camp-Verde-AZ" --stage all

# Run from any stage
uv run python orchestrate_pipeline.py "TierraMark-at-Camp-Verde-AZ" --stage convert
uv run python orchestrate_pipeline.py "TierraMark-at-Camp-Verde-AZ" --stage classify
uv run python orchestrate_pipeline.py "TierraMark-at-Camp-Verde-AZ" --stage extract

# Re-run one extraction agent (without re-running classify/extract)
uv run python run_modular_pipeline.py "listing-docs/TierraMark-at-Camp-Verde-AZ/tierramark_at_camp_verde_az_markdown.md" --stage extract --agent sponsor
```

